{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Fleet",
  "version": "0.1.0",
  "identifier": "com.kjs.fleet",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Fleet",
        "width": 1280,
        "height": 840,
        "dragDropEnabled": false,
        "backgroundColor": "#0e0e11"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Jukim2/fleet/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY5NTJCRjZDMkNBRkExOTAKUldTUW9hOHNiTDlTK2Y2Wmd4cEkyb3NXUmpRTUVrdGlQWTUvcVh3STI3ekIxYWkrc0d3Zi9OaXEK"
    }
  }
}
